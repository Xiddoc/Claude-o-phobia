<?xml version="1.0" encoding="utf-8"?>
<!--
  Tall rendering (roughly 3x2 and up). A weighted Space sits above the caption
  so the content fills the card's height intentionally: header and figure ride
  the top, the caption settles on the bottom, and any extra height the user
  stretches into is absorbed in the middle rather than pooling as dead space.
  Shares its view IDs with widget_usage_compact.xml so one render path feeds both.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="#A39B8D"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:textAllCaps="true"
        android:fontFamily="sans-serif-medium" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:baselineAligned="false"
        android:gravity="bottom">

        <TextView
            android:id="@+id/widget_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="#ECE6DD"
            android:textSize="34sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/widget_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="6dp"
            android:text="of week elapsed"
            android:textColor="#D97757"
            android:textSize="13sp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/widget_progress"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:layout_marginTop="10dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/widget_progress" />

    <!--
      Flexible spacer that pushes the caption to the bottom. Must be a
      LinearLayout, not a <Space>/<View>: RemoteViews only inflates a fixed
      whitelist of view types, and Space isn't on it, so an app widget using
      one fails to render ("Couldn't add widget") whenever this layout is shown.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="10dp"
        android:orientation="vertical" />

    <TextView
        android:id="@+id/widget_caption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#A39B8D"
        android:textSize="11sp" />
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
  Compact graph rendering for short cells: a slim nav row (prev · week label ·
  next) above the curve, no header or caption. Carries the same view IDs as
  widget_graph.xml (including a hidden graph_caption) so the single render path
  can bind both without a missing-view error.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/graph_prev"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_chevron_left"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:contentDescription="@string/graph_prev_week" />

        <TextView
            android:id="@+id/graph_week_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="This week"
            android:textColor="#ECE6DD"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium" />

        <ImageButton
            android:id="@+id/graph_next"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_chevron_right"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:contentDescription="@string/graph_next_week" />
    </LinearLayout>

    <ImageView
        android:id="@+id/graph_image"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp"
        android:scaleType="fitXY"
        android:contentDescription="@string/graph_widget_description" />

    <!-- Present (carries the shared id) but collapsed: compact has no room for it. -->
    <TextView
        android:id="@+id/graph_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:text=""
        android:textColor="#A39B8D"
        android:textSize="10sp"
        android:maxLines="1"
        android:ellipsize="end" />
</LinearLayout>

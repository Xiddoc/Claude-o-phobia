<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Track -->
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="#35302B" />
            <corners android:radius="5dp" />
        </shape>
    </item>

    <!-- Pace marker: a faint clay band reaching to where a steady, evenly-paced
         week would put you. The filled usage layer draws on top, so when you're
         under pace this band peeks out past your usage as visible headroom. -->
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape android:shape="rectangle">
                <solid android:color="#59D97757" />
                <corners android:radius="5dp" />
            </shape>
        </clip>
    </item>

    <!-- Filled progress: a warm clay gradient for a soft glow. -->
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <gradient
                    android:startColor="#D97757"
                    android:endColor="#E89A80"
                    android:angle="0" />
                <corners android:radius="5dp" />
            </shape>
        </clip>
    </item>
</layer-list>

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- We launch the Claude app (the "Open Claude" button) to make the module
         re-capture the session, so we must declare it visible to us on API 30+. -->
    <queries>
        <package android:name="com.anthropic.claude" />
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Claudeophobia">

        <!-- The modern libxposed module metadata (entry class, scope, description,
             API version) lives in META-INF/xposed/* — see module.prop,
             java_init.list and scope.list under src/main/resources. -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Claudeophobia">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Daily pacing nudge: fires once a day at a random daytime moment. -->
        <receiver
            android:name=".notify.NudgeReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.xiddoc.claudeophobia.NUDGE_FIRE" />
            </intent-filter>
        </receiver>

        <!-- Re-arms the nudge alarm after a reboot. -->
        <receiver
            android:name=".notify.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Weekly-progress sampler: fires at the Live Usage sync interval to record
             the cached usage figure (no network). Internal only. -->
        <receiver
            android:name=".notify.HistorySampleReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.xiddoc.claudeophobia.SAMPLE_FIRE" />
            </intent-filter>
        </receiver>

        <!-- Home-screen widget (renders locally; never contacts Claude). -->
        <receiver
            android:name=".widget.UsageWidget"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/usage_widget_info" />
        </receiver>

        <!-- Circular weekly-pace widget (RemoteViews twin of the in-app ring). -->
        <receiver
            android:name=".widget.CircleUsageWidget"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/circle_widget_info" />
        </receiver>

        <!-- Weekly-progress graph widget (Bezier curve + derivative, locally rendered).
             Also handles its own GRAPH_NAV broadcasts for tap week-navigation. -->
        <receiver
            android:name=".widget.HistoryGraphWidget"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.xiddoc.claudeophobia.GRAPH_NAV" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/graph_widget_info" />
        </receiver>

        <!-- Inbound bridge: the LSPosed module (running in the Claude process)
             publishes captured usage snapshots here. Exported so Claude's uid
             can reach it; it only understands the single "publish" call. -->
        <provider
            android:name=".data.UsageProvider"
            android:authorities="${applicationId}.usage"
            android:exported="true" />
    </application>

</manifest>
